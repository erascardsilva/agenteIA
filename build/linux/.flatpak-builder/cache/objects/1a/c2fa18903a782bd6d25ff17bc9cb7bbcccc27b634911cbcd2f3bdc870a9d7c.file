[Application]
name=org.erascardsilva.agenteIA
runtime=org.gnome.Platform/x86_64/45
sdk=org.gnome.Sdk/x86_64/45
command=agenteIA

[Context]
shared=network;ipc;
sockets=x11;wayland;pulseaudio;
devices=dri;
features=devel;
filesystems=home;

[Session Bus Policy]
org.freedesktop.portal.Flatpak=talk
org.freedesktop.SpeechDispatcher=talk
org.speech_dispatcher.SpeechDispatcher=talk

[X-DConf]
comm-read-only=true
